# ── Core API & Security ───────────────────────────────────────────────────────
# Set to true if you have configured SSL/HTTPS for your VPS, otherwise set to false
ENFORCE_HTTPS=true

# Allowed origins for CORS (separated by commas)
ALLOWED_ORIGINS=https://star-farm.vercel.app

# Enable or disable Swagger UI (/docs)
ENABLE_DOCS=false

# Maximum number of API requests allowed per IP per minute
RATE_LIMIT_PER_MIN=60

# Secure API Key(s) to authenticate clients connecting to the MCP (use your own secure string)
API_KEYS=your_vps_private_secure_key_here

# ── Local Storage Paths (Inside Container) ─────────────────────────────────────
# Default path to the simulation CSV dataset inside the container (ADDED / AT THE START)
DEFAULT_CSV_PATH=/app/data/Simulation_Data.csv

# Directory inside the container where trained model caches will be saved (mapped to VPS via volumes)
MODEL_CACHE_DIR=/app/model_cache