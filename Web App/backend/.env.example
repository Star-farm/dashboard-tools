# API key(s) allowed to call protected routes (comma-separated).
API_KEYS="test-key-123"

# Path to the simulation dataset CSV.
DEFAULT_CSV_PATH="data/Simulation_Data.csv"

# Optional. Defaults to a portable model_cache folder under the OS temp directory.
# MODEL_CACHE_DIR="/tmp/model_cache"

# Enable Swagger documentation (true/false)
ENABLE_DOCS="true"
