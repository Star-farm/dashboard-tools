# Backend Configuration
# Copy this file to .env and adjust values as needed.
# NEVER commit the actual .env file to version control.

# Comma-separated list of allowed CORS origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173,http://127.0.0.1:4173
# Set to "true" to expose /docs (OpenAPI). Set to "false" in production.
ENABLE_DOCS=true
